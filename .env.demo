# Demo mode — safe to deploy, no real credentials
DEMO_MODE=true

# PostgreSQL
POSTGRES_USER=budget
POSTGRES_PASSWORD=budget_demo_pass
POSTGRES_DB=budget_demo

# Backend
SECRET_KEY=demo-ephemeral-sessions-only-no-real-data
DATABASE_URL=postgresql+asyncpg://budget:budget_demo_pass@postgres:5432/budget_demo
DATABASE_URL_SYNC=postgresql://budget:budget_demo_pass@postgres:5432/budget_demo

# AI — disabled (demo uses canned responses)
OLLAMA_URL=
OLLAMA_MODEL=

# OAuth — disabled
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URLs
# NEXT_PUBLIC_API_URL uses the Docker Compose service name so the Next.js
# container can reach the backend over the compose network.
# NEXT_PUBLIC_API_DOCKER=1 tells next.config to use this URL for rewrites
# (without it the config falls back to http://localhost:8000, which is the
# loopback inside the container — not the backend service).
FRONTEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://backend:8000
NEXT_PUBLIC_API_DOCKER=1
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_DEMO_MODE=true
