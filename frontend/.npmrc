# openapi-typescript@7.x and @typescript-eslint/eslint-plugin@8.x declare peer
# deps against typescript@^5.x / <6.1.0.  TypeScript 6 is compatible at
# runtime; the peer-dep declarations are simply behind the release curve.
# legacy-peer-deps makes npm install/ci treat these the same way npm 6 did
# (warn, not error) so the lockfile resolves cleanly on CI.
legacy-peer-deps=true
