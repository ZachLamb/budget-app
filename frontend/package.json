    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.7.0",
    "eslint-config-next": "^16.2.9",
    "fallow": "^3.3.0",
    "jsdom": "^29.0.1",
    "knip": "^6.27.0",
    "openapi-typescript": "^7.13.0",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
