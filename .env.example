# Demo mode — enables demo login and canned AI responses (safe for public demos)
# DEMO_MODE=false
# NEXT_PUBLIC_DEMO_MODE=false

# Optional local LLM via Ollama (docker compose includes an ollama service)
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=qwen2.5:7b

# PostgreSQL
POSTGRES_USER=budget
POSTGRES_PASSWORD=          # set a strong password
POSTGRES_DB=budget_app

# Backend — REQUIRED: generate a strong random key (use at least 32 characters; longer is better):
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=                 # REQUIRED — will not start without this
DATABASE_URL=postgresql+asyncpg://budget:YOUR_PASSWORD@postgres:5432/budget_app
DATABASE_URL_SYNC=postgresql://budget:YOUR_PASSWORD@postgres:5432/budget_app

# Google OAuth (optional; leave empty to hide "Sign in with Google")
# Create credentials at https://console.cloud.google.com/apis/credentials
# Set Authorized redirect URI to: http://localhost:8000/api/auth/google/callback (or your backend URL + /api/auth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend URL for redirect after Google sign-in (e.g. http://localhost:3001)
FRONTEND_URL=http://localhost:3001

# Comma-separated allowed browser origins for the API. Do not use "*"; the API uses credential-bearing CORS.
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend: API is same-origin /api; Next.js rewrites to the backend.
# NEXT_PUBLIC_API_URL: rewrite target. If it contains "backend", next.config uses localhost:8000 unless NEXT_PUBLIC_API_DOCKER=1 (set by Docker Compose). So: run full stack in Docker, or run frontend on host with backend on localhost:8000 (rewrite will use localhost automatically).
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Comma-separated IP/CIDR allowlist for reverse proxies that are permitted to
# set X-Forwarded-For. When empty the direct peer IP is always used for rate
# limiting (XFF is ignored). Add your proxy's IP/range here in production so
# per-IP limits key on the real client IP instead of your proxy.
# Fly.io / reverse proxy: CIDRs permitted to set X-Forwarded-For (required on Fly
# so per-IP rate limits key on the real client, not the edge proxy).
# TRUSTED_PROXIES=

# When true and Upstash is configured, /api/auth/* rate limits return 429 if Redis is down.
# AUTH_RATE_LIMIT_STRICT=false

# SimpleFIN outbound SSRF allowlist extras (comma-separated host patterns).
# Production defaults include *.simplefin.org — use only for dev bridges.
# SIMPLEFIN_ALLOWED_HOSTS_EXTRA=localhost

# Optional Upstash Redis (HTTP REST) — when both are set, rate-limit and
# login-lockout counters are shared across workers/replicas. When empty, the
# backend falls back to per-instance in-memory state (dev/single-worker OK).
# Provision at https://console.upstash.com/ or via the Vercel marketplace.
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=
# The Vercel Marketplace integration names these KV_REST_API_URL /
# KV_REST_API_TOKEN. Either naming is accepted — keep whichever your
# environment provisions so re-syncs don't overwrite your rename.
