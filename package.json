{
  "name": "budget-app",
  "private": true,
  "description": "Monorepo root — Next.js app lives in frontend/",
  "scripts": {
    "ci": "./scripts/ci-local.sh",
    "ci:vercel": "./scripts/vercel-build-check.sh",
